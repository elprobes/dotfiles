#!/usr/bin/env bash

# -----------------------------------
# Rofi Quick Calculator
# qalc + xclip + persistent history
# -----------------------------------

HISTORY_FILE="/tmp/rofi-calc-history"
MAX_HISTORY=20

copy_to_clipboard() {
    printf "%s" "$1" | xclip -selection clipboard
}

touch "$HISTORY_FILE"

while true; do

    MENU=$(cat "$HISTORY_FILE")

    INPUT=$(printf "%b" "$MENU" | rofi \
        -dmenu \
        -i \
        -p "Calc" \
        -kb-custom-1 "Alt+d")

    EXIT_CODE=$?

    # -----------------------------------
    # ALT+D -> clear history
    # -----------------------------------
    if [[ $EXIT_CODE -eq 10 ]]; then
        > "$HISTORY_FILE"

        notify-send -u low "Calculator" "History cleared" >/dev/null 2>&1

        continue
    fi

    # ESC
    [[ $EXIT_CODE -ne 0 ]] && exit 0

    # vuoto
    [[ -z "$INPUT" ]] && continue

    # -----------------------------------
    # selezione history
    # -----------------------------------
    if [[ "$INPUT" == *" = "* ]]; then

        RESULT="${INPUT##*= }"

        copy_to_clipboard "$RESULT"

        notify-send -u low "Copied" "$RESULT" >/dev/null 2>&1

        exit 0
    fi

    # -----------------------------------
    # nuovo calcolo
    # -----------------------------------
    RESULT=$(qalc -t "$INPUT" 2>/dev/null)

    [[ -z "$RESULT" ]] && continue

    RESULT="$(echo "$RESULT" | sed 's/^ *//')"

    ENTRY="$INPUT = $RESULT"

    # rimuove duplicati
    grep -Fxv "$ENTRY" "$HISTORY_FILE" > /tmp/rofi-calc-tmp

    {
        echo "$ENTRY"
        cat /tmp/rofi-calc-tmp
    } | head -n "$MAX_HISTORY" > "$HISTORY_FILE"

done

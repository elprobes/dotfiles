#!/usr/bin/env bash

ROFI_THEME='
window {
    width: 38%;
}

listview {
    lines: 8;
    columns: 1;
    spacing: 6px;
    scrollbar: true;
}

element {
    padding: 6px;
}

element-text {
    font: "UbuntuMono Nerd Font 11.5";
}
'

main_choice=$(
    printf '%s\n' \
        "󰗼  Kill process" \
        "󰍃  Logout" \
        "󰜉  Reboot" \
        "󰐥  Shutdown" |
    rofi \
        -dmenu \
        -i \
        -p "Power Menu" \
        -theme-str "$ROFI_THEME"
)

case "$main_choice" in

    "󰗼  Kill process")

        selected=$(
            ps -u "$USER" -ww -o pid=,comm= |
            sed 's/^ *//' |
            rofi \
            -dmenu \
            -i \
            -p "Kill process" \
            -theme-str '
            window {
                width: 40%;
            }

            listview {
                lines: 12;
                scrollbar: true;
            }

            element-text {
                font: "UbuntuMono Nerd Font 11.5";
            }
            ')

        pid=$(awk '{print $1}' <<< "$selected")

        if [ -n "$pid" ]; then
            process_name=$(ps -p "$pid" -o comm=)

            kill "$pid" && \
            notify-send \
                -u normal \
                "󰗼 Process killed" \
                "\"$process_name\" (PID $pid) terminated"
        fi
        ;;

    "󰍃  Logout")
        notify-send -u low "󰍃 Logout" "Exiting i3..."
        i3-msg exit
        ;;

    "󰜉  Reboot")
        notify-send -u low "󰜉 Reboot" "System rebooting..."
        systemctl reboot -i
        ;;

    "󰐥  Shutdown")
        notify-send -u low "󰐥 Shutdown" "Powering off..."
        systemctl poweroff
        ;;

esac

#!/usr/bin/env bash

set -euo pipefail

HISTORY_FILE="${HOME}/.history"

main() {
    local selected

    selected="$(get_history | show_menu)"

    [[ -z "${selected}" ]] && exit 0

    copy_to_clipboard "${selected}"
}

get_history() {

    # Gestisce sia il formato zsh:
    # : 1748645000:0;comando
    #
    # sia il formato bash:
    # comando

    sed 's/^: [0-9]*:[0-9]*;//' "${HISTORY_FILE}" |
    tac |
    awk 'length($0) && !seen[$0]++'
}

show_menu() {
    rofi \
        -dmenu \
        -i \
        -p "" \
        -theme-str 'window {width: 60%;}'
}

copy_to_clipboard() {

    if [[ "${XDG_SESSION_TYPE:-}" == "wayland" ]] \
        && command -v wl-copy >/dev/null 2>&1; then

        printf '%s' "$1" | wl-copy

    elif command -v xclip >/dev/null 2>&1; then

        printf '%s' "$1" | xclip -selection clipboard

    else
        notify-send "Clipboard" \
            "No clipboard utility found"
        return 1
    fi
}

main

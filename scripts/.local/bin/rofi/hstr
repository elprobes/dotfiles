#!/usr/bin/env bash

set -euo pipefail

HISTORY_FILE="${HOME}/.bash_history"

main() {
    local selected

    selected="$(get_history | show_menu)"

    [[ -z "${selected}" ]] && exit 0

    copy_to_clipboard "${selected}"
}

get_history() {
    tac "${HISTORY_FILE}" | awk '!seen[$0]++'
}

show_menu() {
    rofi \
        -dmenu \
        -i \
        -p "" \
        -theme-str 'window {width: 60%;}'
}

copy_to_clipboard() {
    if [[ "${XDG_SESSION_TYPE:-}" == "wayland" ]] \
        && command -v wl-copy >/dev/null 2>&1; then

        printf '%s' "$1" | wl-copy

    elif command -v xclip >/dev/null 2>&1; then

        printf '%s' "$1" | xclip -selection clipboard

    else
        notify-send "Clipboard" "No clipboard utility found"
        return 1
    fi
}

main

#!/usr/bin/env bash

set -euo pipefail

ROFI_THEME='
window {
    width: 38%;
}

listview {
    lines: 8;
    columns: 1;
    spacing: 6px;
    scrollbar: true;
}

element {
    padding: 6px;
}

element-text {
    font: "UbuntuMono Nerd Font 11.5";
}
'

main_choice=$(
    printf '%s\n' \
        "󰗼  Kill process" \
        "󰍃  Logout" \
        "󰜉  Reboot" \
        "󰐥  Shutdown" |
    rofi \
        -dmenu \
        -i \
        -p "Power Menu" \
        -theme-str "$ROFI_THEME"
)

case "$main_choice" in

    # -------------------------------------------------
    # Kill process
    # -------------------------------------------------

    "󰗼  Kill process")

        selected=$(
            ps -u "$USER" -ww -o pid=,comm= |
            sed 's/^ *//' |
            rofi \
                -dmenu \
                -i \
                -p "Kill process" \
                -theme-str '
                window {
                    width: 40%;
                }

                listview {
                    lines: 12;
                    scrollbar: true;
                }

                element-text {
                    font: "UbuntuMono Nerd Font 11.5";
                }
                '
        )

        pid=$(awk '{print $1}' <<< "$selected")

        if [ -n "$pid" ]; then

            process_name=$(ps -p "$pid" -o comm=)

            kill "$pid" && \
            notify-send \
                -u normal \
                -h string:x-canonical-private-synchronous:processkill \
                "󰗼 Process killed" \
                "\"$process_name\" (PID $pid) terminated"
        fi
        ;;

    # -------------------------------------------------
    # Logout
    # -------------------------------------------------

    "󰍃  Logout")

        notify-send \
            -u low \
            -h string:x-canonical-private-synchronous:logout \
            "󰍃 Logout" \
            "Exiting session..."

        if pgrep sway >/dev/null 2>&1; then
            swaymsg exit
        else
            i3-msg exit
        fi
        ;;

    # -------------------------------------------------
    # Reboot
    # -------------------------------------------------

    "󰜉  Reboot")

        notify-send \
            -u low \
            -h string:x-canonical-private-synchronous:reboot \
            "󰜉 Reboot" \
            "System rebooting..."

        systemctl reboot -i
        ;;

    # -------------------------------------------------
    # Shutdown
    # -------------------------------------------------

    "󰐥  Shutdown")

        notify-send \
            -u low \
            -h string:x-canonical-private-synchronous:shutdown \
            "󰐥 Shutdown" \
            "Powering off..."

        systemctl poweroff
        ;;

esac
